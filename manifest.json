{
  "manifest_version": 3,
  "name": "Hate Detector v4",
  "description": "Extensión para navegadores - Detector de discurso de odio basado en BETO para textos en español -",
  "version": "4",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "sidePanel"
  ],
  "host_permissions": [
    "https://router.huggingface.co/*",
    "https://api-inference.huggingface.co/*",
    "https://hatedetector.online/*",
    "<all_urls>"
  ],
  "icons": {
    "16": "img/2.png",
    "32": "img/2.png",
    "48": "img/2.png",
    "128": "img/2.png"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "action": {
    "default_icon": {
      "16": "img/2.png",
      "24": "img/2.png",
      "32": "img/2.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}